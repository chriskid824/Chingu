rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 輔助函數 =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 開發者權限（僅限資料種子工具使用）
    function isDeveloper() {
      return isAuthenticated() &&
             request.auth.token.email != null &&
             request.auth.token.email == 'chriskid824@gmail.com';
    }

    // 是否為聊天室參與者
    function isChatParticipant() {
      return isAuthenticated() &&
             request.auth.uid in resource.data.participantIds;
    }

    // ===== 用戶 =====
    match /users/{userId} {
      // 所有登入用戶可讀（配對、聊天等需要讀取其他用戶基本資料）
      // 上線前收緊：只允許讀取有限欄位
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isDeveloper();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || isDeveloper();
    }

    // ===== 訂閱 =====
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) || isDeveloper();
      allow update: if isOwner(userId) || isDeveloper();
    }

    // ===== 晚餐活動 =====
    match /dinner_events/{eventId} {
      // signedUpUsers 的變動只能是「增或減自己一個人」
      function onlySelfSignupChange() {
        let before = resource.data.signedUpUsers.toSet();
        let after = request.resource.data.signedUpUsers.toSet();
        return (after.difference(before) == [request.auth.uid].toSet()
                && before.difference(after).size() == 0)
            || (before.difference(after) == [request.auth.uid].toSet()
                && after.difference(before).size() == 0);
      }

      allow read: if isAuthenticated();
      // 用戶只能改 signedUpUsers(報名/取消,且只能動自己);
      // status 只允許 open/matching(closed/revealed/completed/cancelled 由 Cloud Functions 寫)
      allow update: if isDeveloper() ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['signedUpUsers', 'status']) &&
         onlySelfSignupChange() &&
         request.resource.data.status in ['open', 'matching']);
      // 只有 Cloud Functions 和開發者可建立/刪除
      allow create: if isDeveloper();
      allow delete: if isDeveloper();
    }

    // ===== 晚餐群組 =====
    match /dinner_groups/{groupId} {
      // 只有參與者可讀
      allow read: if isAuthenticated() &&
                     request.auth.uid in resource.data.participantIds;
      // 只有 Cloud Functions 和開發者可寫;
      // 參與者只能更新出席確認(attendanceConfirmed)
      allow create: if isDeveloper();
      allow update: if isDeveloper() ||
        (isAuthenticated() &&
         request.auth.uid in resource.data.participantIds &&
         request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['attendanceConfirmed']));
      allow delete: if isDeveloper();
    }

    // ===== 聊天室 =====
    match /chat_rooms/{chatRoomId} {
      // 參與者或開發者可讀
      allow read: if isChatParticipant() || isDeveloper();
      // 聊天室一律由 Cloud Functions(Admin SDK,不受 rules 限制)建立:
      // 群聊=週三揭曉、一對一=雙向 Match。client 端已無建立路徑,
      // 開放 create 會讓人偽造任意 participantIds 的房間
      allow create: if isDeveloper();
      // 參與者可更新（發訊息時更新 lastMessage / unreadCount）
      allow update: if isChatParticipant() || isDeveloper();
      allow delete: if isDeveloper();

      // 訊息子集合 — 透過 get() 驗證是否為聊天室參與者
      match /messages/{messageId} {
        function isChatMember() {
          return request.auth.uid in
            get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participantIds;
        }
        allow read: if isAuthenticated() && isChatMember();
        allow create: if isAuthenticated() && isChatMember();
        allow update: if false;
        allow delete: if isDeveloper();
      }
    }

    // ===== 評價（雙盲：只有自己能讀自己寫的） =====
    match /dinner_reviews/{reviewId} {
      allow read: if isAuthenticated() &&
                     resource.data.reviewerId == request.auth.uid;
      // 只能以自己的身分評價(偽造 reviewerId 可騙過 onMutualMatch 強制配對);
      // skipped 由 Cloud Functions 寫入,client 只能 like/dislike
      allow create: if isDeveloper() ||
        (isAuthenticated() &&
         request.resource.data.reviewerId == request.auth.uid &&
         request.resource.data.result in ['like', 'dislike']);
      allow update: if false;  // 評價不可修改
      allow delete: if isDeveloper();
    }

    // ===== 破冰話題 =====
    match /icebreaker_questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper();
    }

    // ===== 餐廳 =====
    match /restaurants/{restaurantId} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper();
    }

    // ===== 檢舉 =====
    match /reports/{reportId} {
      allow read: if false;  // 只有後台可讀
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ===== 通知 =====
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if false;  // 只有 Cloud Functions 可建
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    // ===== 預設：拒絕所有未列出的集合 =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
