rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 輔助函數 =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 開發者權限（僅限資料種子工具使用）
    function isDeveloper() {
      return isAuthenticated() && 
             request.auth.token.email != null && 
             request.auth.token.email == 'chriskid824@gmail.com';
    }

    // ===== 用戶 =====
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isDeveloper();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || isDeveloper();
    }

    // ===== 訂閱 =====
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) || isDeveloper();
      allow update: if isOwner(userId) || isDeveloper();
    }

    // ===== 晚餐活動 =====
    match /dinner_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() || isDeveloper();
      allow update: if isAuthenticated();
      allow delete: if isDeveloper();
    }

    // ===== 群組 =====
    match /dinner_groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isDeveloper();
      allow update: if isAuthenticated();
      allow delete: if isDeveloper();
    }

    // ===== 聊天室 =====
    match /chat_rooms/{chatRoomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() || isDeveloper();
      allow update: if isAuthenticated();
      allow delete: if isDeveloper();
    }

    // ===== 訊息 =====
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isDeveloper();
    }

    // ===== 評價 =====
    match /dinner_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isDeveloper();
    }

    // ===== 檢舉 =====
    match /reports/{reportId} {
      allow read: if false;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ===== 餐廳 =====
    match /restaurants/{restaurantId} {
      allow read: if isAuthenticated();
      allow write: if isDeveloper();
    }

    // ===== 通知 =====
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if false;
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow delete: if false;
    }

    // ===== 預設：拒絕所有未列出的集合 =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
